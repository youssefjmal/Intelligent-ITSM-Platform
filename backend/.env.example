# Backend environment variables
ENV=development
DATABASE_URL=postgresql+psycopg://postgres:YOUR_PASSWORD@localhost:5432/jira_tickets?connect_timeout=10&sslmode=prefer
JWT_SECRET=replace-with-strong-secret-at-least-32-chars
LOG_LEVEL=INFO
REFRESH_COOKIE_NAME=tw_refresh
REFRESH_TOKEN_EXPIRE_DAYS=14
FRONTEND_BASE_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000
ALLOWED_HOSTS=localhost,127.0.0.1
# Secret used only for inbound n8n webhook/auth requests to this backend.
# Generate with: openssl rand -hex 32
# Must match the X-Automation-Secret header sent by n8n workflows.
# Required in production — POST /api/notifications/system is disabled when unset.
N8N_INBOUND_SECRET=
N8N_OUTBOUND_SECRET=
# When running via docker-compose, n8n is available at http://n8n:5678/webhook
# For standalone dev, set to http://localhost:5670/webhook
N8N_WEBHOOK_BASE_URL=http://n8n:5678/webhook
# n8n encryption key — generate with: openssl rand -hex 32
# Required by the n8n service in docker-compose.
N8N_ENCRYPTION_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TLS=true
PASSWORD_RESET_TOKEN_EXPIRE_HOURS=2
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback
# Groq LLM (replaces Ollama for text generation)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
# Ollama — embeddings only (nomic-embed-text must still be running locally)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_EMBED_TIMEOUT_SECONDS=60
OLLAMA_EMBED_NUM_GPU=-1
AI_SLA_RISK_ENABLED=true
# AI SLA risk mode.
# shadow: AI evaluates risk but results are stored only — not shown to users.
# active: AI risk advisory is shown in the ticket detail SLA panel.
# Set to "active" for demo and production use.
# Set to "shadow" only when validating AI quality before exposing to users.
# NOTE: If you have a local .env file, update AI_SLA_RISK_MODE there manually.
AI_SLA_RISK_MODE=active
SLA_AT_RISK_MINUTES=30
SLA_ESCALATE_HIGH_MINUTES=10
SLA_ESCALATE_STEP_MINUTES=30
SLA_STALE_STATUS_MINUTES=120
SLA_DEADLINE_ALERT_MINUTES=30
SLA_AI_HIGH_RISK_SCORE_THRESHOLD=0.8
SLA_ADVISOR_RAG_TOP_K=4
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=
JIRA_SERVICE_DESK_ID=
JIRA_DEFAULT_REQUEST_TYPE_ID=
JIRA_DEFAULT_REQUEST_TYPE_NAME=Emailed request
JIRA_REQUEST_TYPE_FIELD=customfield_10010
JIRA_KB_ENABLED=true
JIRA_KB_MAX_ISSUES=60
JIRA_KB_MAX_COMMENTS_PER_ISSUE=5
JIRA_KB_TOP_MATCHES=5
JIRA_KB_CACHE_SECONDS=300
JIRA_SYNC_PAGE_SIZE=50
JIRA_WEBHOOK_SECRET=
JIRA_AUTO_RECONCILE_ENABLED=true
JIRA_AUTO_RECONCILE_INTERVAL_SECONDS=300
JIRA_AUTO_RECONCILE_LOOKBACK_DAYS=30
JIRA_AUTO_RECONCILE_STARTUP_DELAY_SECONDS=10
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=120
RATE_LIMIT_AUTH_MAX_REQUESTS=20
RATE_LIMIT_AI_MAX_REQUESTS=30
PROMETHEUS_METRICS_ENABLED=true
# Set this to the same long random token used by Prometheus.
PROMETHEUS_METRICS_TOKEN=
