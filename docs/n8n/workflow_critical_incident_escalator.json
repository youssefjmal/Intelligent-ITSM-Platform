          }
        ]
      ]
    },
    "Escalation Email Failed?": {
      "main": [
        [
          {
            "node": "Log Failure",
            "type": "main",
            "index": 0
          }
        ],
        []
      ]
    },
    "Follow-up Email Failed?": {
      "main": [
        [
          {
